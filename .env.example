# Copy to .env for local dev (server reads process.env directly).
PORT=8080
REDIS_URL=redis://127.0.0.1:6379
ORIGIN_ALLOWLIST=https://teman-ninja.com,https://www.teman-ninja.com
STRICT_ORIGIN=false
ROUND_SECONDS=75
COUNTDOWN_SECONDS=3
SCORE_TICK_MS=250
BOT_FALLBACK_MS=10000
MMR_BUCKET=500
RECONNECT_GRACE_MS=10000
SERVER_SHARED_SECRET=
